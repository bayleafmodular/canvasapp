STAFF_EMAILS=staff@example.com

# Optional default admin seed. Run npm run seed:admin after setting these.
DEFAULT_ADMIN_NAME=Default Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_this_password

