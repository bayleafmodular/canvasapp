PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret
# Optional comma-separated allowlists. Matching registered emails get these roles automatically.
ADMIN_EMAILS=admin@example.com
STAFF_EMAILS=staff@example.com

# Optional default admin seed. Run npm run seed:admin after setting these.
DEFAULT_ADMIN_NAME=Default Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_this_password

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=MNG1308 Auth
SMTP_FROM_EMAIL=your-email@example.com
